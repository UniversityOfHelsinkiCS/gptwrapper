{
  "name": "gptwrapper",
  "version": "1.0.0",
  "description": "CurreChat - The GPT chat interface of University of Helsinki",
  "type": "module",
  "scripts": {
    "start": "docker compose up",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "autotest": "vitest watch",
    "prod": "NODE_ENV=production tsx src/server/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "dev:server": "NODE_ENV=development tsx watch --clear-screen=false src/server/index.ts",
    "tsc": "tsc",
    "tsc:on": "tsc --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "build": "vite build",
    "prepare": "husky install",
    "test:e2e": "playwright test",
    "test:e2e:logging": "playwright test --reporter=line --workers=1",
    "test:evals": "node evals/rag-eval.spec.ts",
    "test:record": "playwright codegen -o e2e/recorded.spec.ts localhost:3000",
    "translations": "node scripts/analyzeTranslations.js",
    "migrations": "node scripts/analyzeMigrationNames.js",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UniversityOfHelsinkiCS/GPTwrapper.git"
  },
  "author": "toska.dev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UniversityOfHelsinkiCS/GPTwrapper/issues"
  },
  "homepage": "https://github.com/UniversityOfHelsinkiCS/GPTwrapper#readme",
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@eslint/js": "9.39.4",
    "@locator/babel-jsx": "0.5.1",
    "@playwright/test": "1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "2.8.19",
    "@types/eslint": "9.6.1",
    "@types/express": "5.0.6",
    "@types/lodash": "4.17.24",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/multer-s3": "3.0.3",
    "@types/node": "22.19.19",
    "@types/node-cron": "3.0.11",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-i18next": "6.1.4",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "globals": "16.5.0",
    "happy-dom": "^20.9.0",
